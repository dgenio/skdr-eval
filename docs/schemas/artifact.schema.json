      },
      "title": "Sensitivity",
      "type": "array"
    },
    "skdr_eval_version": {
      "title": "Skdr Eval Version",
      "type": "string"
    },
    "timestamp": {
      "title": "Timestamp",
      "type": "string"
    },
    "warnings": {
