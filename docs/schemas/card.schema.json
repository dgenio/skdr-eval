    "DiagnosticsBlock": {
      "additionalProperties": true,
      "description": "Diagnostic metrics carried on the report row.",
      "properties": {
        "ESS": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ess"
        },
        "brier_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
