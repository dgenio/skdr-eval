{
  "$defs": {
    "BaselineBlock": {
      "additionalProperties": true,
      "description": "Baseline policy value and delta-vs-baseline summary (#132).",
      "properties": {
        "delta_V_hat": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delta V Hat"
        },
        "delta_ci_lower": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delta Ci Lower"
        },
        "delta_ci_upper": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delta Ci Upper"
        },
        "kind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Kind"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "title": "BaselineBlock",
      "type": "object"
    },
    "CoverageSimBlock": {
      "additionalProperties": true,
      "description": "Reference to the last coverage simulation run, if any.",
      "properties": {
        "dgp": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dgp"
        },
        "empirical_coverage": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Empirical Coverage"
        },
        "n_reps": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "N Reps"
        },
        "passes_nominal": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
