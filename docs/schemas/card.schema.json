      "title": "SensitivityBlock",
      "type": "object"
    },
    "TrustBlock": {
      "additionalProperties": true,
      "description": "Support-health / recommendation summary.",
      "properties": {
        "primary_blocker": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
