      "type": "object"
    },
    "EstimandBlock": {
      "additionalProperties": true,
      "description": "Target estimand and assumption tags carried with every card (#128).\n\nThe block makes the *statistical contract* of the report explicit on\nthe artifact and the YAML/JSON card so it travels with the headline.\nDefaults match :data:`DEFAULT_ESTIMAND_TEX`,\n:data:`DEFAULT_ESTIMAND_SUMMARY`, and :data:`DEFAULT_ASSUMPTION_TAGS`.\nSee ``docs/concepts/estimands-and-assumptions.md`` for the prose.",
      "properties": {
        "assumptions": {
          "items": {
            "type": "string"
          },
          "title": "Assumptions",
          "type": "array"
        },
        "docs_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "docs/concepts/estimands-and-assumptions.md",
          "title": "Docs Url"
        },
        "estimand_tex": {
          "default": "V(\\pi) = E_X [ E_{A \\sim \\pi(\\cdot|X)} [ Y(X, A) ] ]",
          "title": "Estimand Tex",
          "type": "string"
        },
        "summary": {
          "default": "Policy value of the target policy over the held-out evaluation slice of the logs, under the assumptions listed in docs/concepts/estimands-and-assumptions.md.",
          "title": "Summary",
          "type": "string"
        }
      },
      "title": "EstimandBlock",
      "type": "object"
    },
    "HeadlineBlock": {
      "additionalProperties": true,
      "description": "Headline metrics for a card.",
      "properties": {
        "V_hat": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "V Hat"
        },
        "baseline": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Baseline"
        },
        "ci_alpha": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ci Alpha"
        },
        "ci_lower": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ci Lower"
        },
        "ci_upper": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ci Upper"
        },
        "clip": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Clip"
        },
        "delta_vs_baseline": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delta Vs Baseline"
        },
        "estimator": {
          "title": "Estimator",
          "type": "string"
        }
      },
      "required": [
        "estimator",
        "V_hat"
      ],
      "title": "HeadlineBlock",
      "type": "object"
    },
    "ProvenanceBlock": {
      "additionalProperties": true,
      "description": "Run provenance metadata.",
      "properties": {
        "evaluator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evaluator"
        },
        "n_samples": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "N Samples"
        },
        "n_splits": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "N Splits"
        },
        "random_state": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Random State"
        },
        "schema_version": {
          "default": "1.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "skdr_eval_version": {
          "default": "unknown",
          "title": "Skdr Eval Version",
          "type": "string"
        },
        "timestamp": {
          "default": "",
          "title": "Timestamp",
          "type": "string"
        }
      },
      "title": "ProvenanceBlock",
      "type": "object"
    },
