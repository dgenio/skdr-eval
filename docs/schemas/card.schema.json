      "title": "TrustBlock",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "Machine-readable sibling of the HTML evaluation card (#88).\n\nBundles the headline result, trust signals, diagnostics, sensitivity, and\nprovenance for a single ``(model, estimator)`` row. Designed to be:\n\n- YAML/JSON serializable for pinning in Git.\n- JSON-Schema exportable for downstream tooling.\n- CI-gateable (``card.trust.recommendation['verdict'] == 'do_not_deploy'``).\n\nSee Also\n--------\nEvaluationArtifact.card_schema : Build a card from a finished artifact.",
  "properties": {
    "baseline": {
      "anyOf": [
        {
          "$ref": "#/$defs/BaselineBlock"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "card_schema_version": {
      "default": "1.1.0",
      "title": "Card Schema Version",
      "type": "string"
    },
    "coverage_sim": {
      "anyOf": [
        {
          "$ref": "#/$defs/CoverageSimBlock"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "diagnostics": {
      "$ref": "#/$defs/DiagnosticsBlock"
    },
    "estimand": {
      "$ref": "#/$defs/EstimandBlock"
    },
    "headline": {
      "$ref": "#/$defs/HeadlineBlock"
    },
    "model_name": {
      "title": "Model Name",
      "type": "string"
    },
    "provenance": {
      "$ref": "#/$defs/ProvenanceBlock"
    },
    "sensitivity": {
      "$ref": "#/$defs/SensitivityBlock"
    },
    "trust": {
      "$ref": "#/$defs/TrustBlock"
    }
  },
  "required": [
    "model_name",
    "headline",
    "trust",
    "diagnostics"
  ],
  "title": "EvaluationCard",
  "type": "object"
}
